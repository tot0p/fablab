{% if item.type == 'file' %}
    <a href="{{ item.url }}" class="nav-item {{ 'active' if page.url == item.url }}">
        <span class="nav-icon">📄</span>
        {{ item.title }}
    </a>
{% elif item.type == 'directory' and item.children.length > 0 %}
    <div class="nav-dropdown">
        <button class="nav-dropdown-toggle" aria-expanded="false">
            <span class="nav-icon">📁</span>
            {{ item.title }}
            <span class="dropdown-arrow">▶</span>
        </button>
        <div class="nav-dropdown-content">
            {% for child in item.children %}
                {% set item = child %}
                {% include "nav-item.njk" %}
            {% endfor %}
        </div>
    </div>
{% endif %}